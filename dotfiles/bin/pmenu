# Power menu (Qtile legacy) ŌĆö no Hyprland use: action.sh --power

# Current Theme
theme='powermenu.rasi'

# Options
shutdown='¾░Éź'
reboot='¾░£ē'
lock='¾░īŠ'
suspend='¾░żä'
logout='¾░łå'
yes='’üś'
no='’üŚ'

# Rofi CMD
rofi_cmd() {
  rofi -dmenu \
    -theme ${theme}
}

# Confirmation CMD
confirm_cmd() {
    rofi -dmenu \
        -p 'Confirmation' \
        -mesg 'Are you Sure?' \
        -theme confirm.rasi
}

# Ask for confirmation
confirm_exit() {
    echo -e "$yes\n$no" | confirm_cmd
}

# Pass variables to rofi dmenu
run_rofi() {
    echo -e "$lock\n$suspend\n$logout\n$reboot\n$shutdown" | rofi_cmd
}

# Execute Command
run_cmd() {
    selected="$(confirm_exit)"
    if [[ "$selected" == "$yes" ]]; then
        if [[ $1 == '--shutdown' ]]; then
            systemctl poweroff
        elif [[ $1 == '--reboot' ]]; then
            systemctl reboot
        elif [[ $1 == '--suspend' ]]; then
            systemctl suspend
        elif [[ $1 == '--logout' ]]; then
            if command -v hyprctl >/dev/null && [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" || -d "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr" ]]; then
                hyprctl dispatch exit
            elif [[ -n "${XDG_SESSION_ID:-}" ]]; then
                loginctl terminate-session "$XDG_SESSION_ID" --no-ask-password
            else
                loginctl terminate-user "$USER" --no-ask-password
            fi
        fi
    else
        exit 0
    fi
}

# Actions
chosen="$(run_rofi)"
case ${chosen} in
$shutdown)
    run_cmd --shutdown
    ;;
$reboot)
    run_cmd --reboot
    ;;
$lock)
    if command -v hyprlock >/dev/null; then
        hyprlock
    elif command -v betterlockscreen >/dev/null; then
        betterlockscreen -l blur
    fi
    ;;
$suspend)
    run_cmd --suspend
    ;;
$logout)
    run_cmd --logout
    ;;
esac
